


export type component SomeComponent
{
    // Public

    pub fn (self: ref mut SomeComponent) some_func() -> void {}

    type struct SomeStruct
    {
        mut x: int;
    }
}

namespace SomeNamespace {export fn do_thing(x: ref mut * int) -> void {}}

export fn main() -> void
{
    for(let mut i: u64; i < 5; ++i)
    {
        i -= 1;
    }


    let arr: int[3];

    let mut t: SomeStruct;

    t.x = 0;

    do_thing(&t.x + 3 - 12.3 / 4);

    if(t.x == 0)
    {
        t.x = 1;
    }

    else if(t.x == -1)
    {
        t.x = 0;
    }

    for(let mut i: int = 0; i < 3; ++i)
    {
        ++t.x;
    }

    arr[t.x];

    ret 0;
}