fn set_mem(*mut u8 mem, u8 val, u64 num_bytes) -> void
{
    for(mut u64 i = 0; i < num_bytes; ++i)
    {
        mem[i] = val;
    }
}

fn alloc_mem(u64 num_bytes) -> *mut opaque
{
    *mut opaque mem = // ... Alloc some mem;

    ret mem;
}

fn free_mem(*mut opaque mem) -> void
{
    if(mem == null)
    {
        runtime_error("Attempted to free a null pointer");
    }

    // Free mem...
}

fn copy_mem(*mut opaque dst, * opaque src, u64 num_bytes) -> void
{
    (dst > src) ? Internal::copy_mem_bwd(dst, src, num_bytes) : 
        Internal::copy_mem_fwd(dst, src, num_bytes);
}

} // namespace Serac
